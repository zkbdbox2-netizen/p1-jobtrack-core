# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# =============================================================================
# Environment & Secrets — NEVER commit these
# =============================================================================
.env
.env.*
!.env.example        # allow the example template (no real secrets)
*.pem
*.key
secrets/

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# =============================================================================
# Testing & Coverage
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# =============================================================================
# Alembic generated bytecode (versions themselves should be committed)
# =============================================================================
alembic/__pycache__/
alembic/versions/__pycache__/

# =============================================================================
# Docker
# =============================================================================
*.log

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp
